# Copy to .env.local for development.
# In Vercel, set these in Project -> Settings -> Environment Variables.

NEXT_PUBLIC_API_URL=http://localhost:8000/api

# WhatsApp floating button. Use international format, digits only.
# Example: 923001234567 for +92 300 1234567 (Pakistan).
# Leave blank to hide the button.
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hi! I have a question about my order on Apni Dukan.
